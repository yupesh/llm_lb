{
  "$defs": {
    "JudgeSpec": {
      "additionalProperties": false,
      "description": "LLM-as-Judge configuration. The judge model scores each candidate\nanswer on an integer scale; the runner normalises into [0, 1].\n\nThe judge prompt may use placeholders {prompt}, {expected}, {prediction}.",
      "properties": {
        "model": {
          "title": "Model",
          "type": "string"
        },
        "prompt": {
          "title": "Prompt",
          "type": "string"
        },
        "scale_min": {
          "default": 0,
          "title": "Scale Min",
          "type": "integer"
        },
        "scale_max": {
          "default": 5,
          "title": "Scale Max",
          "type": "integer"
        },
        "forbid_self_judge": {
          "default": true,
          "title": "Forbid Self Judge",
          "type": "boolean"
        },
        "served_model_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Served Model Name"
        }
      },
      "required": [
        "model",
        "prompt"
      ],
      "title": "JudgeSpec",
      "type": "object"
    },
    "LLMParams": {
      "additionalProperties": false,
      "properties": {
        "temperature": {
          "default": 0.0,
          "title": "Temperature",
          "type": "number"
        },
        "top_p": {
          "default": 1.0,
          "title": "Top P",
          "type": "number"
        },
        "max_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        }
      },
      "title": "LLMParams",
      "type": "object"
    },
    "MetricSpec": {
      "additionalProperties": false,
      "properties": {
        "primary": {
          "title": "Primary",
          "type": "string"
        },
        "secondary": {
          "items": {
            "type": "string"
          },
          "title": "Secondary",
          "type": "array"
        }
      },
      "required": [
        "primary"
      ],
      "title": "MetricSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "name": {
      "title": "Name",
      "type": "string"
    },
    "version": {
      "title": "Version",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "metric": {
      "$ref": "#/$defs/MetricSpec"
    },
    "labels": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Labels"
    },
    "label_aliases": {
      "anyOf": [
        {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Label Aliases"
    },
    "llm_params": {
      "$ref": "#/$defs/LLMParams"
    },
    "system_prompt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "System Prompt"
    },
    "prompt_template": {
      "title": "Prompt Template",
      "type": "string"
    },
    "answer_regex": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Answer Regex"
    },
    "judge": {
      "anyOf": [
        {
          "$ref": "#/$defs/JudgeSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "runner_kind": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Runner Kind"
    },
    "max_turns": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Max Turns"
    },
    "context_file": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Context File"
    },
    "context_meta_key": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Context Meta Key"
    }
  },
  "required": [
    "name",
    "version",
    "metric",
    "llm_params",
    "prompt_template"
  ],
  "title": "TaskSpec",
  "type": "object"
}