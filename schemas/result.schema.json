{
  "$defs": {
    "LLMParams": {
      "additionalProperties": false,
      "properties": {
        "temperature": {
          "default": 0.0,
          "title": "Temperature",
          "type": "number"
        },
        "top_p": {
          "default": 1.0,
          "title": "Top P",
          "type": "number"
        },
        "max_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        },
        "reasoning_mode": {
          "anyOf": [
            {
              "enum": [
                "off",
                "low",
                "medium",
                "high"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Mode"
        }
      },
      "title": "LLMParams",
      "type": "object"
    },
    "SamplePrediction": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "prediction": {
          "title": "Prediction",
          "type": "string"
        },
        "expected": {
          "title": "Expected",
          "type": "string"
        },
        "correct": {
          "title": "Correct",
          "type": "boolean"
        },
        "latency_ms": {
          "title": "Latency Ms",
          "type": "number"
        },
        "input_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "output_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "raw_output": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Output"
        },
        "judge_raw_score": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Judge Raw Score"
        },
        "error": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error"
        }
      },
      "required": [
        "id",
        "prediction",
        "expected",
        "correct",
        "latency_ms"
      ],
      "title": "SamplePrediction",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "model_id": {
      "title": "Model Id",
      "type": "string"
    },
    "model_revision": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Revision"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
    "task_version": {
      "title": "Task Version",
      "type": "string"
    },
    "runner_version": {
      "title": "Runner Version",
      "type": "string"
    },
    "prompt_template_hash": {
      "title": "Prompt Template Hash",
      "type": "string"
    },
    "llm_params": {
      "$ref": "#/$defs/LLMParams"
    },
    "metrics": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Metrics",
      "type": "object"
    },
    "tps": {
      "title": "Tps",
      "type": "number"
    },
    "p95_latency_ms": {
      "title": "P95 Latency Ms",
      "type": "number"
    },
    "n_samples": {
      "title": "N Samples",
      "type": "integer"
    },
    "n_failed_samples": {
      "default": 0,
      "title": "N Failed Samples",
      "type": "integer"
    },
    "samples": {
      "items": {
        "$ref": "#/$defs/SamplePrediction"
      },
      "title": "Samples",
      "type": "array"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "env": {
      "additionalProperties": true,
      "title": "Env",
      "type": "object"
    },
    "cost_usd": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cost Usd"
    },
    "judge_model_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Judge Model Id"
    },
    "judge_model_revision": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Judge Model Revision"
    },
    "judge_prompt_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Judge Prompt Hash"
    },
    "judge_served_model_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Judge Served Model Name"
    }
  },
  "required": [
    "model_id",
    "task_id",
    "task_version",
    "runner_version",
    "prompt_template_hash",
    "llm_params",
    "metrics",
    "tps",
    "p95_latency_ms",
    "n_samples",
    "samples",
    "created_at"
  ],
  "title": "RunResult",
  "type": "object"
}